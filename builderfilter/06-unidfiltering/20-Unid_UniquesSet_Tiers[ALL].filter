//-----------------------------------------------------------------------------------
// IMPORTANT DROPS
// Filter level 1-4 Shows all set/unique
// Filter level 5-6 Shows GG,3,2,1,0 Tiers below & Elite Unique & Set or Unique Eth
// Filter level 7  Shows GG,3,2,1 Tiers below  & Set or Unique Eth
//-----------------------------------------------------------------------------------

//  Boss Items
//-----------------------------------------------------------------------------------
// The Third Eye Amulet
// Cage of the Unsullied Boneweave
// Band of Skulls Troll Belt
// Aidans Scar - Scissors Suwayyah
// Cage of the Unsullied - Boneweave
// Dark Abyss - Lacquered Plate
// Band of Skulls - Troll Belt
// Itheraels Path - Mirrored Boots
// Overlords Helm - Giant Conch
// Hadriels Hand - Conquest Sword

ItemDisplay[UNI !ID (ram OR rar OR rbe OR 7qr OR uhn OR uth OR utc OR utb OR uhl OR 7bs OR 7cr2)]: %SOUNDID-4719%%UNI_BOSS_ITEM%

// 4 Star Unique Callouts
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<11 4_STAR_UNIQUE]: %UNI_GG_ITEM%

// 4 Star Unique Callouts only when ETH
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID ETH FILTLVL<11 4_STAR_ETH_UNIQUE]: %UNI_GG_ITEM%

// Jewerly
//-----------------------------------------------------------------------------------
// Amulet
// Ring
ItemDisplay[UNI !ID FILTLVL<11 (amu OR rin)]: %UNI_GG_ITEM%

// Rainbow Facet
ItemDisplay[jew UNI !ID FILTLVL<11]: %SOUNDID-4719%%FACET_ITEM%

// 3 Star Unique Callouts
// Filter level 1-8
//-----------------------------------------------------------------------------------

ItemDisplay[UNI !ID FILTLVL<9 3_STAR_UNIQUE]: %SOUNDID-4726%%UNI_STAR3_ITEM%

// 2 Star Unique Callouts
// Filter level 1-7
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<8 2_STAR_UNIQUE]: %SOUNDID-4715%%UNI_STAR2_ITEM%

// 1 Star Unique Callouts
// Filter level 1-7
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<8 1_STAR_UNIQUE]: %UNI_STAR1_ITEM%

// 0 Star Unique Callouts
// Filter level 1-7
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<8 0_STAR_UNIQUE]: %UNI_STAR0_ITEM%

// 00 Star Unique Callouts
// Filter level 1-6
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<7 NO_STAR_UNIQUE]: %UNI_STAR0_ITEM%

//  lld catch callouts as Tier 1
//-----------------------------------------------------------------------------------
ItemDisplay[UNI !ID FILTLVL<7 LLD_UNIQUE]: %UNI_STAR1_ITEM%

// Set GG Set Callouts
//-----------------------------------------------------------------------------------
// Tancreds Hobnails - Boots

ItemDisplay[SET !ID lbt]: %SOUNDID-4719%%SET_GG_ITEM%

// Set Ring
// Set Amulet
ItemDisplay[SET !ID (amu OR rin) FILTLVL<6]: %SET_TIER3_ITEM%
ItemDisplay[SET !ID amu FILTLVL<7]: %NAME%
ItemDisplay[SET !ID rin FILTLVL<8]: %NAME%

// Only ETH
// Immortal Kings Stone Crusher - Ogre Maul
// Bul-Kathos Sacred Charge - Colossus Blade
// Bul-Kathos Tribal Guardian - Colossus Sword

ItemDisplay[SET !ID ETH (7m7 OR 7gd OR 7fb) FILTLVL<9]: %SET_GG_ITEM%

// Set tier 3 Set Callouts
//-----------------------------------------------------------------------------------
ItemDisplay[SET !ID FILTLVL<9 3_STAR_SET]: %SET_TIER3_ITEM%

// Set tier 2 Set Callouts
//-----------------------------------------------------------------------------------
ItemDisplay[SET !ID FILTLVL<8 2_STAR_SET]: %SET_TIER2_ITEM%

// Any ETH Set weapon catch rest
ItemDisplay[SET !ID ETH WEAPON FILTLVL<7]: %SET_TIER2_ITEM%
ItemDisplay[SET !ID ETH WEAPON FILTLVL<8]: %NAME%

// Set tier 1 Set Callouts
//-----------------------------------------------------------------------------------
ItemDisplay[SET !ID FILTLVL<7 1_STAR_SET]: %SET_TIER1_ITEM%

// Set tier 0 Set Callouts
//-----------------------------------------------------------------------------------
ItemDisplay[SET !ID FILTLVL<5 0_STAR_SET]: %GREEN%%NAME%

// LLD  lld catch callouts
//-----------------------------------------------------------------------------------
ItemDisplay[SET !ID FILTLVL<7 LLD_SET]: %SET_TIER1_ITEM%%TIER-6%

//-----------------------------------------------------------------------------------
